<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>tr</string>
	<key>CFBundleDisplayName</key>
	<string>NetTapu</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>tr</string>
		<string>en</string>
	</array>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- App Transport Security: enforce HTTPS, with explicit exception for our API host. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>nettapu-2.tunasoft.tech</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<false/>
				<key>NSExceptionMinimumTLSVersion</key>
				<string>TLSv1.2</string>
			</dict>
		</dict>
	</dict>
	<!-- Permission usage strings (App Store review-ready, KVKK uyumlu) -->
	<key>NSCameraUsageDescription</key>
	<string>NetTapu, ilanlarınıza kapak ve detay fotoğrafı eklemeniz için kameraya ihtiyaç duyuyor.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>NetTapu, ilanlarınıza fotoğraf ekleyebilmeniz için galerinize erişim izni istiyor.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>NetTapu, ilan fotoğraflarınızı kaydetmek için galerinize erişim istiyor.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>İhale sırasında sesli arama özelliği için mikrofona erişim istiyoruz.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Yakınınızdaki arsa ilanlarını harita üzerinde gösterebilmek için konumunuzu kullanıyoruz.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Hesabınıza güvenli giriş yapabilmek için Face ID kullanıyoruz.</string>
	<key>NSContactsUsageDescription</key>
	<string>Yetkili danışmanlarınızla hızlı paylaşım için rehberinize erişebiliriz.</string>
	<key>NSUserTrackingUsageDescription</key>
	<string>Size kişiselleştirilmiş ilan önerileri ve daha iyi bir deneyim sunmak için.</string>
	<!-- Universal links / WhatsApp / tel: open externally -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>whatsapp</string>
		<string>tel</string>
		<string>mailto</string>
		<string>sms</string>
		<string>maps</string>
		<string>comgooglemaps</string>
	</array>
	<key>RCTNewArchEnabled</key>
	<true/>
	<key>UIAppFonts</key>
	<array>
		<string>Ionicons.ttf</string>
		<string>MaterialIcons.ttf</string>
		<string>MaterialCommunityIcons.ttf</string>
		<string>FontAwesome.ttf</string>
		<string>FontAwesome5_Solid.ttf</string>
		<string>FontAwesome5_Regular.ttf</string>
		<string>FontAwesome5_Brands.ttf</string>
		<string>Fontisto.ttf</string>
		<string>Octicons.ttf</string>
		<string>Feather.ttf</string>
		<string>FontAwesome6_Regular.ttf</string>
		<string>Entypo.ttf</string>
		<string>AntDesign.ttf</string>
		<string>Foundation.ttf</string>
		<string>Zocial.ttf</string>
		<string>EvilIcons.ttf</string>
		<string>FontAwesome6_Solid.ttf</string>
		<string>SimpleLineIcons.ttf</string>
		<string>FontAwesome6_Brands.ttf</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
	<key>UIUserInterfaceStyle</key>
	<string>Automatic</string>
</dict>
</plist>
