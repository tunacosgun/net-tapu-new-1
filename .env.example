# ══════════════════════════════════════════════════════════════
# NetTapu Platform — Environment Variables
# ══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
POSTGRES_MIGRATOR_PASSWORD=migrator_secret_change_me
POSTGRES_APP_PASSWORD=app_secret_change_me

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret_change_me

# ── JWT / Authentication ──────────────────────────────────────
JWT_SECRET=change_me_in_production_min_32_chars!!
JWT_ISSUER=nettapu
JWT_AUDIENCE=nettapu-platform

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=*

# ── Auction Engine ────────────────────────────────────────────
SNIPER_EXTENSION_SECONDS=60

# ── POS Provider (mock | paytr | iyzico) ──────────────────────
POS_PROVIDER=mock

# PayTR Configuration (when POS_PROVIDER=paytr)
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_BASE_URL=https://www.paytr.com

# iyzico Configuration (when POS_PROVIDER=iyzico)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ── Email Provider (SendGrid) ─────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@nettapu.com

# ── SMS Provider (NetGSM) ────────────────────────────────────
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=NETTAPU

# ── Push Notifications (Firebase) ─────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Notification Dispatch Worker ──────────────────────────────
NOTIFICATION_DISPATCH_ENABLED=true
NOTIFICATION_POLL_INTERVAL_MS=5000
NOTIFICATION_BATCH_SIZE=10

# ── Auth Settings ─────────────────────────────────────────────
EMAIL_VERIFICATION_EXPIRY_HOURS=24
PASSWORD_RESET_EXPIRY_MINUTES=30

# ── Internal Service Communication ────────────────────────────
MONOLITH_INTERNAL_URL=http://monolith:3000
INTERNAL_SERVICE_KEY=change_me_internal_service_secret

# ── Workers ───────────────────────────────────────────────────
DISABLE_WORKERS=false
RECONCILIATION_ENABLED=true
OUTBOX_POLL_INTERVAL_MS=200
OUTBOX_BATCH_SIZE=50
NOTIFICATION_CONSUMER_ENABLED=true
